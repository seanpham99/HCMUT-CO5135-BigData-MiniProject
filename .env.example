# Environment variables for news_scoring_supabase.ipynb
# Copy to .env and fill your own values.
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_KEY=sb_secret_<your_service_or_secret_key>
SUPABASE_SCHEMA=market_data
ROW_LIMIT=401

# Optional: enables semantic scoring with Gemini embeddings
GOOGLE_API_KEY=<your_google_api_key>
