# ============================================================
# AIRFLOW DATA PIPELINE ENVIRONMENT VARIABLES
# ============================================================
# This service runs independently and calls the core NestJS API.
#
# Deployment Architecture:
# - Core Web/API: core repository deployment
# - Airflow Pipeline: VPS/Coolify (THIS SERVICE)
# - Supabase: External (Postgres + Auth)
# - Upstash: External (Redis)
# ============================================================

# Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


# Airflow Configuration
# REQUIRED (Production): set all secrets to strong random values
# OPTIONAL (Local dev): values can be left blank for quick-start defaults
# Generate: openssl rand -base64 32
AIRFLOW_UID=1001
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__API__SECRET_KEY=
AIRFLOW__API_AUTH__JWT_SECRET=
# Local default works when compose project directory is data-pipeline.
# If your deploy tool needs an explicit Dockerfile path, set AIRFLOW_DOCKERFILE_PATH=Dockerfile.
# AIRFLOW_DOCKERFILE_PATH=Dockerfile

# Airflow Admin Login (Web UI)
# REQUIRED (Production): use non-default credentials
# OPTIONAL (Local dev): fallback is airflow / airflow
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=choose-a-strong-password

# Database (Supabase - External)
SUPABASE_DB_URL=
SUPABASE_URL=
SUPABASE_SECRET_OR_SERVICE_ROLE_KEY=

# ============================================================
# CRITICAL: NestJS API Connection (Railway)
# ============================================================
# This URL must point to your Railway-deployed NestJS API
# Find this in Railway Dashboard > api service > Settings > Domains
#
# Format: https://your-api-service.up.railway.app
# Example: https://api-portfolios-tracker.up.railway.app
#
# For local development: http://host.docker.internal:3001
# For Railway production: https://your-api.up.railway.app
NESTJS_API_URL=http://host.docker.internal:3001

# ============================================================
# CRITICAL: API Authentication Key
# ============================================================
# This key authenticates Airflow DAGs calling Railway API endpoints
# MUST match the DATA_PIPELINE_API_KEY in Railway API service
#
# Generate a secure key: openssl rand -base64 32
# Set the SAME value in:
#   1. This file (VPS/Coolify Airflow)
#   2. Railway Dashboard > api service > Variables > DATA_PIPELINE_API_KEY
DATA_PIPELINE_API_KEY=your-secret-key-for-airflow

# ============================================================
# DEPLOYMENT CHECKLIST:
# ============================================================
# [ ] Set Airflow admin login (_AIRFLOW_WWW_USER_USERNAME/_AIRFLOW_WWW_USER_PASSWORD)
# [ ] Set Airflow secrets (FERNET/API/JWT) with strong random values
# [ ] Generate secure API key (openssl rand -base64 32)
# [ ] Set NESTJS_API_URL to Railway API domain
# [ ] Set DATA_PIPELINE_API_KEY (same in Railway and here)
# [ ] Test connection: curl -H "X-Api-Key: key" https://your-api.up.railway.app/health
# [ ] Verify Supabase connectivity from VPS
# [ ] Configure Supabase connection
# [ ] Test full DAG run: portfolio_daily_snapshot
# ============================================================
