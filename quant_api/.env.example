# ── Supabase ──────────────────────────────────────────────────────────────
# Your Supabase project URL (found in Project Settings → API)
SUPABASE_URL=https://<your-project-ref>.supabase.co

# Service-role key (Settings → API → service_role). Keep this secret!
SUPABASE_SERVICE_KEY=

# Schema that holds the news / assets tables
SUPABASE_SCHEMA=market_data

# ── PostgreSQL / pgvector ─────────────────────────────────────────────────
# Connection string for the self-hosted pgvector instance (docker-compose)
DATABASE_URL=postgresql://vnstock:vnstock@localhost:5432/vnstock

# ── Sentence-Transformer Embedding Model ─────────────────────────────────
# Any model from https://huggingface.co/sentence-transformers
EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBED_DIM=384

# ── Stock Data Defaults ────────────────────────────────────────────────────
DEFAULT_START=2020-01-01
# Data source: VCI | KBS  (KBS is most reliable for quote.history as of vnstock 3.5)
DEFAULT_SOURCE=VCI

# ── Risk / Finance ────────────────────────────────────────────────────────
# Vietnamese risk-free rate (annual, decimal) — e.g. 4.5% = 0.045
RISK_FREE_RATE=0.045

# ── API Server ────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
